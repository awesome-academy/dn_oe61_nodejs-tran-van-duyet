<form class="row g-3 mb-4" method="get" action="/revenue">
  <div class="col-auto">
    <label for="start">Start Date</label>
    <input type="date" name="start" id="start" class="form-control" value="{{filters.start}}">
  </div>
  <div class="col-auto">
    <label for="end">End Date</label>
    <input type="date" name="end" id="end" class="form-control" value="{{filters.end}}">
  </div>
  <div class="col-auto">
    <label for="group">Group By</label>
    <select name="group" id="group" class="form-select">
      <option value="month" {{#ifEquals filters.group "month"}}selected{{/ifEquals}}>Month</option>
      <option value="year" {{#ifEquals filters.group "year"}}selected{{/ifEquals}}>Year</option>
    </select>
  </div>
  <div class="col-auto align-self-end">
    <button type="submit" class="btn btn-primary">Filter</button>
  </div>
</form>

<canvas id="revenueChart" style="width:100%; height:350px;"></canvas>

<!-- Optional Table -->
    <table class="table table-bordered table-hover align-middle mt-4">
      <thead class="table-light text-center">
        <tr>
          <th>#</th>
          <th>Plan</th>
          <th>User Count</th>
          <th>Revenue</th>
        </tr>
      </thead>
      <tbody>
        {{#each data}}
          <tr class="text-center">
            <td>{{@index}}</td>
            <td>{{plan_name}}</td>
            <td>{{user_count}}</td>
            <td>${{revenue}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const periods = {{{json periods}}};
  const datasets = {{{json datasets}}};

  const ctx = document.getElementById('revenueChart');
  new Chart(ctx.getContext('2d'), {
    type: 'bar',
    data: { labels: periods, datasets },
    options: { responsive: true, maintainAspectRatio: true, scales: { y: { beginAtZero: true } } }
  });
</script>
